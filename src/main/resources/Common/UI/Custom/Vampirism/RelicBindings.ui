// Selection hint label below the slot bar
Label #SelectionHint {
  Anchor: (Left: 0, Right: 0, Top: 218, Height: 22);
  Text: "Select an unlocked ability, then click a slot to bind it.";
  Style: (FontSize: 12, TextColor: #cccccc, HorizontalAlignment: Center);
}

// Ability list panel — central container, cards appended dynamically by Java.
// Plain Group (no LayoutMode) so Java can position children via setObject Anchor.
Group #AbilityListPanel {
  Anchor: (Left: 60, Right: 60, Top: 252, Bottom: 88);
  Background: #000000(0.3);
}

// Apply button bottom-right
Group #ApplyBtnWrapper {
  Anchor: (Right: 60, Bottom: 28, Width: 200, Height: 44);

  $C.@TextButton #ApplyBtn {
    @Text = "Apply";
    @Anchor = (Full: 0);
  }
}

// Unsaved-changes confirmation overlay — hidden by default, shown when navigating away with unsaved edits.
Group #UnsavedChangesOverlay {
  Anchor: (Full: 0);
  Visible: false;

  // Full-screen dim + click blocker
  Button #OverlayBlocker {
    Anchor: (Full: 0);
    Background: #000000(0.5);
  }

  // Center the dialog
  Group {
    Anchor: (Full: 0);
    LayoutMode: CenterMiddle;

    $C.@Panel #UnsavedDialog {
      Anchor: (Width: 390, Height: 218);
      Padding: (Full: 16);
      LayoutMode: Top;

      Label {
        Anchor: (Left: 0, Right: 0, Height: 22);
        Text: "UNSAVED CHANGES";
        Style: $C.@SubtitleStyle;
      }

      Group { Anchor: (Left: 0, Right: 0, Height: 8); }
      $C.@ContentSeparator {}
      Group { Anchor: (Left: 0, Right: 0, Height: 10); }

      Label {
        Anchor: (Left: 0, Right: 0, Height: 42);
        Text: "You have unsaved changes. What would you like to do?";
        Style: (FontSize: 13, TextColor: $C.@ColorDefaultLabel, Wrap: true, HorizontalAlignment: Center);
      }

      Group { Anchor: (Left: 0, Right: 0, Height: 10); }

      Group {
        Anchor: (Left: 0, Right: 0, Height: 38);

        $C.@TextButton #SaveAndLeaveBtn {
          @Text = "Save & Leave";
          @Anchor = (Left: 0, Width: 181, Height: 38);
        }

        $C.@CancelTextButton #DiscardAndLeaveBtn {
          @Text = "Discard & Leave";
          @Anchor = (Right: 0, Width: 181, Height: 38);
        }
      }

      Group { Anchor: (Left: 0, Right: 0, Height: 8); }

      Group {
        Anchor: (Left: 0, Right: 0, Height: 38);
        LayoutMode: CenterMiddle;

        $C.@SecondaryTextButton #CancelLeaveBtn {
          @Text = "Cancel";
          @Anchor = (Width: 181, Height: 38);
        }
      }
    }
  }
}
