// Hytale UI Definition: RelicBindings
// Controller: RelicBindingsUI.java
$C = "../Common.ui";
$Sounds = "../Sounds.ui";

Group #RelicBindingsRoot {
  Anchor: (Full: 0);
  Background: "Background/SkillTreeBackground.png";
}

// Navigation tabs — top-left corner, browser-tab style (active = current page, no button)
Group #NavTabs {
  Anchor: (Left: 0, Top: 0, Width: 290, Height: 44);

  // Inactive tab — clicking navigates to Skill Tree
  Group #TabSkillTreeWrapper {
    Anchor: (Left: 0, Top: 0, Width: 140, Height: 44);
    Background: #0d1820;
    Label {
      Anchor: (Full: 0);
      Text: "Skill Tree";
      Style: (FontSize: 12, TextColor: #999999, HorizontalAlignment: Center, VerticalAlignment: Center);
    }
    Button #TabSkillTreeBtn {
      Anchor: (Full: 0);
      Style: $C.@TertiaryButtonStyle;
    }
  }

  // Active tab — Relic Bindings is the current page, no Button (not clickable)
  Group #TabRelicBindings {
    Anchor: (Left: 144, Top: 0, Width: 146, Height: 44);
    Background: #1e3048;
    Label {
      Anchor: (Full: 0);
      Text: "Relic Bindings";
      Style: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
    }
  }
}

// Header buttons — close and reset, top-right corner
Group #HeaderBtns {
  Anchor: (Right: 16, Top: 14, Width: 220, Height: 38);

  $C.@SecondaryTextButton #ResetBtn {
    @Text = "Reset";
    @Anchor = (Right: 110, Width: 100, Height: 32);
  }

  $C.@CancelTextButton #CloseBtn {
    @Text = "Close";
    @Anchor = (Right: 0, Width: 100, Height: 32);
  }
}

// 5 fixed slot tiles — GridCell pattern: background on Button, icon sibling on top.
// 5 tiles * 96 + 4 gaps * 12 = 528.
Group #SlotsBar {
  Anchor: (Left: 0, Right: 0, Top: 80, Height: 130);
  LayoutMode: CenterMiddle;

  Group {
    Anchor: (Width: 528, Height: 130);

    Group #SlotPrimary {
      Anchor: (Left: 0, Top: 0, Width: 96, Height: 130);

      Group #SlotTile {
        Anchor: (Left: 0, Top: 0, Width: 96, Height: 96);
        Background: (TexturePath: "Common/ItemQualities/Slots/SlotCommon.png");
      }

      Group #SlotIcon {
        Anchor: (Left: 0, Top: 0, Width: 96, Height: 96);
        Visible: false;
        Background: #000000(0);
      }

      Group #RarityOverlay {
        Anchor: (Left: 0, Top: 0, Width: 96, Height: 96);
        Visible: true;
        Background: (TexturePath: "Common/ItemQualities/Slots/SlotCommon_Overlay.png");
        HitTestVisible: false;
      }

      Group #CooldownOverlay {
        Anchor: (Left: 0, Top: 0, Width: 96, Height: 96);
        Visible: false;
        Background: #000000(0.62);
        HitTestVisible: false;
      }

      Label #CooldownText {
        Anchor: (Left: 6, Right: 6, Top: 34, Height: 28);
        Visible: false;
        Text: "";
        Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        HitTestVisible: false;
      }

      Button #SlotHitArea {
        Anchor: (Left: 0, Top: 0, Width: 96, Height: 96);
        Style: (
          Sounds: $Sounds.@CosmeticsTiles,
          Hovered: (Background: (TexturePath: "Skills/Tiles/TileHovered.png")),
          Pressed: (Background: (TexturePath: "Skills/Tiles/TileSelected.png"))
        );
      }

      Group #ClearBtnWrapper {
        Anchor: (Right: 2, Top: 2, Width: 18, Height: 18);
        Background: #1a2a3a;
        Label {
          Anchor: (Full: 0);
          Text: "X";
          Style: (FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #ffffff);
        }
        Button #ClearBtn { Anchor: (Full: 0); Style: $C.@TertiaryButtonStyle; }
      }

      Label #SlotKey {
        Anchor: (Left: 0, Right: 0, Top: 96, Height: 14);
        Text: "Primary";
        Style: (FontSize: 10, TextColor: #999999, HorizontalAlignment: Center);
      }

      Label #SlotName {
        Anchor: (Left: 0, Right: 0, Top: 112, Height: 18);
        Text: "—";
        Style: (FontSize: 12, TextColor: #ffffff, HorizontalAlignment: Center, RenderBold: true);
      }
    }

    Group #SlotSecondary {
