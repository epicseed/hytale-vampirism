$C = "../../Common.ui";

@PointButtonStyle = ButtonStyle(
  Default: (Background: #000000(0.0)),
  Hovered: (Background: #ffffff(0.06)),
  Pressed: (Background: #ffffff(0.12)),
  Disabled: (Background: #000000(0.0)),
  Sounds: $C.@ButtonSounds,
);

Group #RitualBookPoint {
  Anchor: (Width: 64, Height: 64);

  Group #PointGlow {
    Anchor: (Full: 0);
    Background: #6c4f3f;
    Visible: false;
  }

  Group #PointPlate {
    Anchor: (Left: -10, Top: -10, Width: 84, Height: 84);
    Background: #000000(0.0);
  }

  Group #PointGlyph {
    Anchor: (Left: -8, Top: -8, Width: 80, Height: 80);
    Background: "../Assets/Rituals/Vampirism_RitualGlyph_Symbol_Generic.png";
  }

  Group #PointDormantShade {
    Anchor: (Full: 0);
    Background: #1f120b(0.22);
    Visible: true;
  }

  Button #PointTooltip {
    Anchor: (Full: 0);
    Style: @PointButtonStyle;
  }

  Label #PointIndex {
    Anchor: (Left: 22, Top: 44, Width: 20, Height: 14);
    Text: "1";
    Style: (FontSize: 8, RenderBold: true, TextColor: #f7e7c8, HorizontalAlignment: Center, VerticalAlignment: Center);
  }
}
