$C = "../../Common.ui";

@TabButtonStyle = ButtonStyle(
  Default: (Background: #000000(0.0)),
  Hovered: (Background: #ffffff(0.06)),
  Pressed: (Background: #ffffff(0.12)),
  Disabled: (Background: #000000(0.0)),
  Sounds: $C.@ButtonSounds,
);

Group #RitualBookTab {
  Anchor: (Width: 104, Height: 30);

  Group #TabPlate {
    Anchor: (Left: 0, Top: 0, Width: 104, Height: 30);
    Background: #50372c;
  }

  Group #TabSelectionAccent {
    Anchor: (Left: 0, Top: 0, Width: 5, Height: 30);
    Background: #f0d8ab;
    Visible: false;
  }

  Group #TabCompletionAccent {
    Anchor: (Right: 0, Top: 0, Width: 5, Height: 30);
    Background: #b38d45;
    Visible: false;
  }

  Group #TabInset {
    Anchor: (Left: 6, Top: 5, Right: 6, Bottom: 5);
    Background: #50372c;
  }

  Button #TabButton {
    Anchor: (Full: 0);
    Style: @TabButtonStyle;
  }

  Group #TabIcon {
    Anchor: (Left: 4, Top: 4, Width: 22, Height: 22);
    Background: "../Assets/Rituals/Vampirism_RitualGlyph_Symbol_Generic.png";
  }

  Label #TabTitle {
    Anchor: (Left: 38, Top: 6, Right: 10, Bottom: 6);
    Text: "";
    Style: (FontSize: 10, RenderBold: true, TextColor: #d2b59a, HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
  }
}
