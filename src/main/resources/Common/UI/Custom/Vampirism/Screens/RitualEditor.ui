Group #RitualEditorRoot {
  Anchor: (Full: 0);
  Background: #050608(0.96);
}

Group #HeaderBar {
  Anchor: (Left: 20, Right: 20, Top: 18, Height: 36);
}

Label #Title {
  Anchor: (Left: 0, Top: 0, Width: 420, Height: 30);
  Text: "Ritual Editor (Dev)";
  Style: (FontName: "Secondary", FontSize: 20, TextColor: #f4d1da, RenderBold: true);
  HitTestVisible: false;
}

Group #CloseButtonWrap {
  Anchor: (Right: 0, Top: 0, Width: 120, Height: 32);
  Background: #4d1d24;

  Label {
    Anchor: (Full: 0);
    Text: "Close";
    Style: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
    HitTestVisible: false;
  }

  Button #CloseBtn {
    Anchor: (Full: 0);
    Style: (
      Hovered: (Background: #ffffff(0.05)),
      Pressed: (Background: #ffffff(0.12))
    );
  }
}

Group #LeftPanel {
  Anchor: (Left: 20, Top: 68, Width: 320, Bottom: 20);
