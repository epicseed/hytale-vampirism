// Hytale UI Definition: RitualBook
$C = "../../Common.ui";

@BookBackground = PatchStyle(TexturePath: "../Assets/RitualBook/BG.png");
@SectionDividerColor = #7f624d(0.42);
@DiagramFieldTint = #eadcc4(0.72);
@PageBoundsTint = #f1e4cf(0.18);

@BookButtonStyle = ButtonStyle(
  Default: (Background: #50372c),
  Hovered: (Background: #684839),
  Pressed: (Background: #422d24),
  Disabled: (Background: #3a2821),
  Sounds: $C.@ButtonSounds,
);

Group #RitualBookRoot {
  Anchor: (Width: 1240, Height: 888);

  Group #BookFrame {
    Anchor: (Left: 15, Top: 12, Width: 1210, Height: 864);
    Background: @BookBackground;
  }

  Group #SpineShadow {
    Anchor: (Left: 614, Top: 70, Width: 8, Height: 748);
    Background: #5d4737;
  }

  Group #LeftTabGutter {
    Anchor: (Left: 0, Top: 104, Width: 104, Height: 552);
  }

  Group #RightTabGutter {
    Anchor: (Right: 0, Top: 104, Width: 104, Height: 552);
  }

  Group #HeaderControls {
    Anchor: (Right: 72, Top: 28, Width: 96, Height: 34);
    Button #CloseBtn {
      Anchor: (Full: 0);
      Style: @BookButtonStyle;
    }
    Label {
      Anchor: (Full: 0);
      Text: "Close";
      Style: (FontSize: 11, RenderBold: true, TextColor: #f6e7c6, HorizontalAlignment: Center, VerticalAlignment: Center);
    }
  }

  Group #LeftPage {
    Anchor: (Left: 110, Top: 58, Width: 488, Height: 660);

    Group #LeftPageBounds {
      Anchor: (Full: 0);
      Background: @PageBoundsTint;
      Group #LeftPageContent {
        Anchor: (Left: 18, Top: 10, Right: 18, Bottom: 10);

        Label #BookTitle {
          Anchor: (Left: 0, Top: 0, Right: 0, Height: 42);
          Text: "";
          Style: (FontName: "Secondary", FontSize: 33, RenderBold: true, TextColor: #24140d, Wrap: true);
        }

        Group #OverviewCard {
          Anchor: (Left: 0, Top: 56, Right: 0, Height: 120);

          Group #IconFrame {
            Anchor: (Left: 10, Top: 10, Width: 76, Height: 76);
            Background: #573f32;
            Group #RitualIcon {
              Anchor: (Left: 6, Top: 6, Width: 64, Height: 64);
            }
          }

          Label #DescriptionText {
            Anchor: (Left: 98, Top: 8, Right: 0, Height: 56);
            Text: "";
            Style: (FontSize: 14, TextColor: #2a1a12, Wrap: true);
          }

          Group {
            Anchor: (Left: 98, Top: 70, Right: 0, Height: 1);
            Background: #baa185;
          }

          Label #OverviewLine {
            Anchor: (Left: 98, Top: 78, Right: 0, Bottom: 8);
            Text: "";
            Style: (FontSize: 13, TextColor: #7d573f, RenderBold: true, Wrap: true);
          }
        }

        Group #RequirementsCard {
          Anchor: (Left: 0, Top: 190, Right: 0, Height: 219);
          Group {
            Anchor: (Left: 0, Right: 0, Top: 0, Height: 1);
            Background: @SectionDividerColor;
          }
          Label {
            Anchor: (Left: 0, Top: 10, Width: 250, Height: 20);
            Text: "Requirements & blockers";
            Style: (FontName: "Secondary", FontSize: 16, RenderBold: true, TextColor: #22150f);
          }
          Label {
            Anchor: (Left: 0, Top: 40, Width: 150, Height: 16);
            Text: "Requirements";
            Style: (FontSize: 11, RenderBold: true, TextColor: #8a5b43);
          }
          Label #RequirementsText {
            Anchor: (Left: 0, Top: 60, Width: 198, Bottom: 8);
            Text: "";
            Style: (FontSize: 12, TextColor: #2f1f16, Wrap: true);
          }
          Group {
            Anchor: (Left: 214, Top: 40, Width: 1, Bottom: 8);
            Background: @SectionDividerColor;
          }
          Label {
            Anchor: (Left: 232, Top: 40, Width: 150, Height: 16);
            Text: "Blockers";
            Style: (FontSize: 11, RenderBold: true, TextColor: #8a5b43);
          }
          Label #BlockersText {
            Anchor: (Left: 232, Top: 60, Right: 0, Bottom: 8);
            Text: "";
            Style: (FontSize: 12, TextColor: #2f1f16, Wrap: true);
          }
        }

        Group #ObjectivesCard {
          Anchor: (Left: 0, Top: 421, Right: 0, Height: 219);
          Group {
            Anchor: (Left: 0, Right: 0, Top: 0, Height: 1);
            Background: @SectionDividerColor;
          }
          Label {
            Anchor: (Left: 0, Top: 10, Width: 220, Height: 20);
            Text: "Objectives & rewards";
            Style: (FontName: "Secondary", FontSize: 16, RenderBold: true, TextColor: #22150f);
          }
          Label {
            Anchor: (Left: 0, Top: 40, Width: 150, Height: 16);
            Text: "Objectives";
            Style: (FontSize: 11, RenderBold: true, TextColor: #8a5b43);
          }
          Label #ObjectivesText {
            Anchor: (Left: 0, Top: 60, Width: 198, Bottom: 8);
            Text: "";
            Style: (FontSize: 12, TextColor: #2f1f16, Wrap: true);
          }
          Group {
            Anchor: (Left: 214, Top: 40, Width: 1, Bottom: 8);
            Background: @SectionDividerColor;
          }
          Label {
            Anchor: (Left: 232, Top: 40, Width: 150, Height: 16);
            Text: "Rewards";
            Style: (FontSize: 11, RenderBold: true, TextColor: #8a5b43);
          }
          Label #RewardsText {
            Anchor: (Left: 232, Top: 60, Right: 0, Bottom: 8);
            Text: "";
            Style: (FontSize: 12, TextColor: #2f1f16, Wrap: true);
          }
        }
      }
    }
  }

  Group #RightPage {
    Anchor: (Left: 640, Top: 58, Width: 488, Height: 660);

    Group #RightPageBounds {
      Anchor: (Full: 0);
      Background: @PageBoundsTint;
      Group #RightPageContent {
        Anchor: (Left: 18, Top: 10, Right: 18, Bottom: 10);

        Group #DiagramCard {
          Anchor: (Left: 0, Top: 0, Right: 0, Height: 566);

          Group #DiagramField {
            Anchor: (Left: 70, Top: 131, Width: 312, Height: 304);
            Background: @DiagramFieldTint;

            Group #DiagramCanvas {
              Anchor: (Left: 12, Top: -6, Width: 288, Height: 288);
            }

            Group #DiagramAnchor {
              Anchor: (Left: 130, Top: 100, Width: 52, Height: 52);
              Background: #574132;
              Group #DiagramAnchorCore {
                Anchor: (Left: 10, Top: 10, Width: 32, Height: 32);
                Background: #6c4f3f;
              }
            }
          }
        }

        Group #AttuneCard {
          Anchor: (Left: 0, Top: 578, Right: 0, Bottom: 0);
          Group {
            Anchor: (Left: 0, Right: 0, Top: 0, Height: 1);
            Background: @SectionDividerColor;
          }
          Button #AttuneBtn {
            Anchor: (Left: 126, Top: 14, Width: 200, Height: 36);
            Style: @BookButtonStyle;
          }
          Label #AttuneBtnLabel {
            Anchor: (Left: 126, Top: 14, Width: 200, Height: 36);
            Text: "Attune Ritual";
            Style: (FontSize: 11, RenderBold: true, TextColor: #f6e7c6, HorizontalAlignment: Center, VerticalAlignment: Center);
          }
        }
      }
    }
  }
}
