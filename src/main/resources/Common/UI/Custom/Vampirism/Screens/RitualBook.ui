// Hytale UI Definition: RitualBook
$C = "../../Common.ui";

@BookBackground = PatchStyle(TexturePath: "../Assets/RitualBook/BG.png");
@ChecklistDecoration = PatchStyle(TexturePath: "../Assets/RitualBook/RitualChecklist_Glyph.png");
@SectionDividerColor = #3a2015(0.78);
@PageBoundsTint = #f1e4cf(0);
@InkStrong = #120805;
@InkBody = #1e0f08;
@InkMuted = #3c1f13;
@RewardChipBackground = #3b241b(0.78);
@RewardChipText = #f7e3bf;

@BookButtonStyle = ButtonStyle(
  Default: (Background: #50372c),
  Hovered: (Background: #684839),
  Pressed: (Background: #422d24),
  Disabled: (Background: #3a2821),
  Sounds: $C.@ButtonSounds,
);

Group #RitualBookRoot {
  Anchor: (Width: 1240, Height: 888);

  Group #BookFrame {
    Anchor: (Left: 15, Top: 12, Width: 1210, Height: 864);
    Background: @BookBackground;
  }

  Group #SpineShadow {
    Anchor: (Left: 614, Top: 70, Width: 8, Height: 748);
    Background: #5d4737;
  }

  Group #LeftTabGutter {
    Anchor: (Left: 0, Top: 104, Width: 104, Height: 552);
  }

  Group #RightTabGutter {
    Anchor: (Right: 0, Top: 104, Width: 104, Height: 552);
  }

  Group #HeaderControls {
    Anchor: (Right: 72, Top: 28, Width: 96, Height: 34);
    Button #CloseBtn {
      Anchor: (Full: 0);
      Style: @BookButtonStyle;
    }
    Label {
      Anchor: (Full: 0);
      Text: "Close";
      Style: (FontSize: 11, RenderBold: true, TextColor: #f6e7c6, HorizontalAlignment: Center, VerticalAlignment: Center);
    }
  }

  Group #LeftPage {
    Anchor: (Left: 110, Top: 58, Width: 488, Height: 660);

    Group #LeftPageBounds {
      Anchor: (Full: 0);
      Background: @PageBoundsTint;
      Group #LeftPageContent {
        Anchor: (Left: 18, Top: 10, Right: 18, Bottom: 10);

        Label #BookTitle {
          Anchor: (Left: 0, Top: 0, Right: 0, Height: 42);
          Text: "";
          Style: (FontName: "Secondary", FontSize: 33, RenderBold: true, TextColor: @InkStrong, Wrap: true);
        }

        Group #OverviewCard {
          Anchor: (Left: 0, Top: 56, Right: 0, Height: 120);

          Group #IconFrame {
            Anchor: (Left: 10, Top: 10, Width: 76, Height: 76);
            Background: #2b1710;
            Group #RitualIcon {
              Anchor: (Left: 6, Top: 6, Width: 64, Height: 64);
            }
          }

          Label #DescriptionText {
            Anchor: (Left: 98, Top: 8, Right: 0, Height: 56);
            Text: "";
            Style: (FontSize: 14, RenderBold: true, TextColor: @InkBody, Wrap: true);
          }

          Group {
            Anchor: (Left: 98, Top: 70, Right: 0, Height: 1);
            Background: @SectionDividerColor;
          }

          Label #OverviewLine {
            Anchor: (Left: 98, Top: 78, Right: 0, Bottom: 8);
            Text: "";
            Style: (FontSize: 13, TextColor: #4e1f12, RenderBold: true, Wrap: true);
          }
        }

        Group #RitualChecklistCard {
          Anchor: (Left: 0, Top: 190, Right: 0, Height: 450);
          Group {
            Anchor: (Left: 0, Right: 0, Top: 0, Height: 1);
            Background: @SectionDividerColor;
          }
          Label {
            Anchor: (Left: 0, Top: 10, Width: 250, Height: 20);
            Text: "Ritual checklist";
            Style: (FontName: "Secondary", FontSize: 16, RenderBold: true, TextColor: @InkStrong);
          }
          Label {
            Anchor: (Right: 0, Top: 12, Width: 160, Height: 16);
            Text: "requirements + objectives";
            Style: (FontSize: 10, RenderBold: true, TextColor: #5c2414, HorizontalAlignment: End);
          }
          Group #ChecklistDecoration {
            Anchor: (Left: 238, Top: 88, Width: 190, Height: 188);
            Background: @ChecklistDecoration;
            HitTestVisible: false;
          }
          Group #ChecklistRow0 {
            Anchor: (Left: 0, Top: 42, Right: 0, Height: 36);
            Group #ChecklistIcon0 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Background: #2b1710; }
            Label #ChecklistMark0 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Text: ""; Style: (FontSize: 9, RenderBold: true, TextColor: #f6e7c6, HorizontalAlignment: Center, VerticalAlignment: Center); }
            Label #ChecklistTitle0 { Anchor: (Left: 36, Top: 1, Width: 150, Height: 16); Text: ""; Style: (FontSize: 12, RenderBold: true, TextColor: @InkStrong); }
            Label #ChecklistDetail0 { Anchor: (Left: 36, Top: 17, Right: 0, Height: 17); Text: ""; Style: (FontSize: 11, RenderBold: true, TextColor: @InkMuted, Wrap: true); }
            Group #ChecklistProgressTrack0 { Anchor: (Right: 0, Top: 13, Width: 90, Height: 5); Background: #2e170d(0.55); Group #ChecklistProgressFill0 { Anchor: (Left: 0, Top: 0, Width: 0, Height: 5); Background: #4b2215; } }
          }
          Group #ChecklistRow1 {
            Anchor: (Left: 0, Top: 82, Right: 0, Height: 36);
            Group #ChecklistIcon1 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Background: #2b1710; }
            Label #ChecklistMark1 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Text: ""; Style: (FontSize: 9, RenderBold: true, TextColor: #f6e7c6, HorizontalAlignment: Center, VerticalAlignment: Center); }
            Label #ChecklistTitle1 { Anchor: (Left: 36, Top: 1, Width: 150, Height: 16); Text: ""; Style: (FontSize: 12, RenderBold: true, TextColor: @InkStrong); }
            Label #ChecklistDetail1 { Anchor: (Left: 36, Top: 17, Right: 0, Height: 17); Text: ""; Style: (FontSize: 11, RenderBold: true, TextColor: @InkMuted, Wrap: true); }
            Group #ChecklistProgressTrack1 { Anchor: (Right: 0, Top: 13, Width: 90, Height: 5); Background: #2e170d(0.55); Group #ChecklistProgressFill1 { Anchor: (Left: 0, Top: 0, Width: 0, Height: 5); Background: #4b2215; } }
          }
          Group #ChecklistRow2 {
            Anchor: (Left: 0, Top: 122, Right: 0, Height: 36);
            Group #ChecklistIcon2 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Background: #2b1710; }
            Label #ChecklistMark2 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Text: ""; Style: (FontSize: 9, RenderBold: true, TextColor: #f6e7c6, HorizontalAlignment: Center, VerticalAlignment: Center); }
            Label #ChecklistTitle2 { Anchor: (Left: 36, Top: 1, Width: 150, Height: 16); Text: ""; Style: (FontSize: 12, RenderBold: true, TextColor: @InkStrong); }
            Label #ChecklistDetail2 { Anchor: (Left: 36, Top: 17, Right: 0, Height: 17); Text: ""; Style: (FontSize: 11, RenderBold: true, TextColor: @InkMuted, Wrap: true); }
            Group #ChecklistProgressTrack2 { Anchor: (Right: 0, Top: 13, Width: 90, Height: 5); Background: #2e170d(0.55); Group #ChecklistProgressFill2 { Anchor: (Left: 0, Top: 0, Width: 0, Height: 5); Background: #4b2215; } }
          }
          Group #ChecklistRow3 {
            Anchor: (Left: 0, Top: 162, Right: 0, Height: 36);
            Group #ChecklistIcon3 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Background: #2b1710; }
            Label #ChecklistMark3 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Text: ""; Style: (FontSize: 9, RenderBold: true, TextColor: #f6e7c6, HorizontalAlignment: Center, VerticalAlignment: Center); }
            Label #ChecklistTitle3 { Anchor: (Left: 36, Top: 1, Width: 150, Height: 16); Text: ""; Style: (FontSize: 12, RenderBold: true, TextColor: @InkStrong); }
            Label #ChecklistDetail3 { Anchor: (Left: 36, Top: 17, Right: 0, Height: 17); Text: ""; Style: (FontSize: 11, RenderBold: true, TextColor: @InkMuted, Wrap: true); }
            Group #ChecklistProgressTrack3 { Anchor: (Right: 0, Top: 13, Width: 90, Height: 5); Background: #2e170d(0.55); Group #ChecklistProgressFill3 { Anchor: (Left: 0, Top: 0, Width: 0, Height: 5); Background: #4b2215; } }
          }
          Group #ChecklistRow4 {
            Anchor: (Left: 0, Top: 202, Right: 0, Height: 36);
            Group #ChecklistIcon4 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Background: #2b1710; }
            Label #ChecklistMark4 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Text: ""; Style: (FontSize: 9, RenderBold: true, TextColor: #f6e7c6, HorizontalAlignment: Center, VerticalAlignment: Center); }
            Label #ChecklistTitle4 { Anchor: (Left: 36, Top: 1, Width: 150, Height: 16); Text: ""; Style: (FontSize: 12, RenderBold: true, TextColor: @InkStrong); }
            Label #ChecklistDetail4 { Anchor: (Left: 36, Top: 17, Right: 0, Height: 17); Text: ""; Style: (FontSize: 11, RenderBold: true, TextColor: @InkMuted, Wrap: true); }
            Group #ChecklistProgressTrack4 { Anchor: (Right: 0, Top: 13, Width: 90, Height: 5); Background: #2e170d(0.55); Group #ChecklistProgressFill4 { Anchor: (Left: 0, Top: 0, Width: 0, Height: 5); Background: #4b2215; } }
          }
          Group #ChecklistRow5 {
            Anchor: (Left: 0, Top: 242, Right: 0, Height: 36);
            Group #ChecklistIcon5 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Background: #2b1710; }
            Label #ChecklistMark5 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Text: ""; Style: (FontSize: 9, RenderBold: true, TextColor: #f6e7c6, HorizontalAlignment: Center, VerticalAlignment: Center); }
            Label #ChecklistTitle5 { Anchor: (Left: 36, Top: 1, Width: 150, Height: 16); Text: ""; Style: (FontSize: 12, RenderBold: true, TextColor: @InkStrong); }
            Label #ChecklistDetail5 { Anchor: (Left: 36, Top: 17, Right: 0, Height: 17); Text: ""; Style: (FontSize: 11, RenderBold: true, TextColor: @InkMuted, Wrap: true); }
            Group #ChecklistProgressTrack5 { Anchor: (Right: 0, Top: 13, Width: 90, Height: 5); Background: #2e170d(0.55); Group #ChecklistProgressFill5 { Anchor: (Left: 0, Top: 0, Width: 0, Height: 5); Background: #4b2215; } }
          }
          Group #ChecklistRow6 {
            Anchor: (Left: 0, Top: 282, Right: 0, Height: 36);
            Group #ChecklistIcon6 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Background: #2b1710; }
            Label #ChecklistMark6 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Text: ""; Style: (FontSize: 9, RenderBold: true, TextColor: #f6e7c6, HorizontalAlignment: Center, VerticalAlignment: Center); }
            Label #ChecklistTitle6 { Anchor: (Left: 36, Top: 1, Width: 150, Height: 16); Text: ""; Style: (FontSize: 12, RenderBold: true, TextColor: @InkStrong); }
            Label #ChecklistDetail6 { Anchor: (Left: 36, Top: 17, Right: 0, Height: 17); Text: ""; Style: (FontSize: 11, RenderBold: true, TextColor: @InkMuted, Wrap: true); }
            Group #ChecklistProgressTrack6 { Anchor: (Right: 0, Top: 13, Width: 90, Height: 5); Background: #2e170d(0.55); Group #ChecklistProgressFill6 { Anchor: (Left: 0, Top: 0, Width: 0, Height: 5); Background: #4b2215; } }
          }
          Group #ChecklistRow7 {
            Anchor: (Left: 0, Top: 322, Right: 0, Height: 36);
            Group #ChecklistIcon7 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Background: #2b1710; }
            Label #ChecklistMark7 { Anchor: (Left: 0, Top: 5, Width: 26, Height: 26); Text: ""; Style: (FontSize: 9, RenderBold: true, TextColor: #f6e7c6, HorizontalAlignment: Center, VerticalAlignment: Center); }
            Label #ChecklistTitle7 { Anchor: (Left: 36, Top: 1, Width: 150, Height: 16); Text: ""; Style: (FontSize: 12, RenderBold: true, TextColor: @InkStrong); }
            Label #ChecklistDetail7 { Anchor: (Left: 36, Top: 17, Right: 0, Height: 17); Text: ""; Style: (FontSize: 11, RenderBold: true, TextColor: @InkMuted, Wrap: true); }
            Group #ChecklistProgressTrack7 { Anchor: (Right: 0, Top: 13, Width: 90, Height: 5); Background: #2e170d(0.55); Group #ChecklistProgressFill7 { Anchor: (Left: 0, Top: 0, Width: 0, Height: 5); Background: #4b2215; } }
          }
          Group {
            Anchor: (Left: 0, Right: 0, Top: 374, Height: 1);
            Background: @SectionDividerColor;
          }
          Label {
            Anchor: (Left: 0, Top: 386, Width: 90, Height: 16);
            Text: "Rewards";
            Style: (FontSize: 11, RenderBold: true, TextColor: #5c2414);
          }
          Group #RewardChip0 {
            Anchor: (Left: 0, Top: 408, Width: 142, Height: 30);
            Background: @RewardChipBackground;
            Label #RewardMark0 { Anchor: (Left: 8, Top: 0, Width: 24, Height: 30); Text: ""; Style: (FontSize: 12, RenderBold: true, TextColor: #ffd79a, HorizontalAlignment: Center, VerticalAlignment: Center); }
            Label #RewardText0 { Anchor: (Left: 36, Top: 0, Right: 8, Height: 30); Text: ""; Style: (FontSize: 10, RenderBold: true, TextColor: @RewardChipText, Wrap: true, VerticalAlignment: Center); }
          }
          Group #RewardChip1 {
            Anchor: (Left: 154, Top: 408, Width: 142, Height: 30);
            Background: @RewardChipBackground;
            Label #RewardMark1 { Anchor: (Left: 8, Top: 0, Width: 24, Height: 30); Text: ""; Style: (FontSize: 12, RenderBold: true, TextColor: #ffd79a, HorizontalAlignment: Center, VerticalAlignment: Center); }
            Label #RewardText1 { Anchor: (Left: 36, Top: 0, Right: 8, Height: 30); Text: ""; Style: (FontSize: 10, RenderBold: true, TextColor: @RewardChipText, Wrap: true, VerticalAlignment: Center); }
          }
          Group #RewardChip2 {
            Anchor: (Left: 308, Top: 408, Width: 142, Height: 30);
            Background: @RewardChipBackground;
            Label #RewardMark2 { Anchor: (Left: 8, Top: 0, Width: 24, Height: 30); Text: ""; Style: (FontSize: 12, RenderBold: true, TextColor: #ffd79a, HorizontalAlignment: Center, VerticalAlignment: Center); }
            Label #RewardText2 { Anchor: (Left: 36, Top: 0, Right: 8, Height: 30); Text: ""; Style: (FontSize: 10, RenderBold: true, TextColor: @RewardChipText, Wrap: true, VerticalAlignment: Center); }
          }
        }
      }
    }
  }

  Group #RightPage {
    Anchor: (Left: 640, Top: 58, Width: 488, Height: 660);

    Group #RightPageBounds {
      Anchor: (Full: 0);
      Background: @PageBoundsTint;
      Group #RightPageContent {
        Anchor: (Left: 8, Top: 4, Right: 8, Bottom: 4);

        Group #DiagramCard {
          Anchor: (Left: 0, Top: 26, Right: 0, Bottom: 104);

          Group #DiagramField {
            Anchor: (Left: 0, Top: 0, Right: 0, Height: 472);

            Group #DiagramBase {
              Anchor: (Full: 0);
              Background: #000000(0.0);
              Group #DiagramBaseGlyph {
                Anchor: (Left: 32, Top: 28, Width: 408, Height: 472);
                Background: #000000(0.0);
              }
            }

            Group #DiagramCanvas {
              Anchor: (Full: 18);
            }

            Group #DiagramCore {
              Anchor: (Left: 174, Top: 174, Width: 124, Height: 124);
              Background: #000000(0.0);
            }
          }
        }

        Group #AttuneCard {
          Anchor: (Left: 0, Right: 0, Bottom: 46, Height: 58);
          Group {
            Anchor: (Left: 0, Right: 0, Top: 0, Height: 1);
            Background: @SectionDividerColor;
          }
          Button #AttuneBtn {
            Anchor: (Left: 136, Top: 12, Width: 200, Height: 36);
            Style: @BookButtonStyle;
          }
          Label #AttuneBtnLabel {
            Anchor: (Left: 136, Top: 12, Width: 200, Height: 36);
            Text: "Attune Ritual";
            Style: (FontSize: 11, RenderBold: true, TextColor: #f6e7c6, HorizontalAlignment: Center, VerticalAlignment: Center);
          }
        }
      }
    }
  }
}
