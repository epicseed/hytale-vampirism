$C = "../../../Common.ui";
$Sounds = "../../../Sounds.ui";

Group {
  Anchor: (Width: 64, Height: 64);

  Group #SkillTile {
    Anchor: (Full: 0);
    Background: (TexturePath: "Vampirism/Assets/Common/ItemQualities/Slots/SlotRare.png");
  }

  Group #SkillIcon {
    Anchor: (Full: 0);
    Background: #000000(0);
  }

  Group #RarityOverlay {
    Anchor: (Full: 0);
    Visible: true;
    Background: (TexturePath: "Vampirism/Assets/Common/ItemQualities/Slots/SlotRare_Overlay.png");
    HitTestVisible: false;
  }

  Label #OverlayText {
    Anchor: (Right: 3, Bottom: 3, Width: 28, Height: 14);
    Visible: false;
    Text: "";
    Style: (FontSize: 11, TextColor: #ffffff, RenderBold: true, Alignment: Center);
    HitTestVisible: false;
  }

  Group #Indicator {
    Anchor: (Full: 0);
    Background: (TexturePath: "Vampirism/Assets/Skills/Indicators/AvailableIndicator.png");
  }

  Group #Selected {
    Anchor: (Full: 0);
    Visible: false;
    Background: (TexturePath: "Vampirism/Assets/Skills/Tiles/TileSelected.png");
  }

  Button #HitArea {
    Anchor: (Full: 0);
    TooltipText: "";
    TextTooltipStyle: TextTooltipStyle(
      Background: PatchStyle(TexturePath: "Vampirism/Assets/Common/ItemQualities/Tooltips/ItemTooltipRare.png", Border: 24),
      MaxWidth: 400,
      LabelStyle: LabelStyle(Wrap: true, FontSize: 16, TextColor: #4a90d9),
      Padding: 24
    );
    Style: (
      Sounds: $Sounds.@CosmeticsTiles,
      Hovered: (Background: (TexturePath: "Vampirism/Assets/Skills/Tiles/TileHovered.png")),
      Pressed: (Background: (TexturePath: "Vampirism/Assets/Skills/Tiles/TileSelected.png"))
    );
  }

}
