Group {
  // Left half of H: from left edge to center+4
  Group #StripH {
    Anchor: (Left: 0, Right: 28, Top: 28, Height: 8);
    Background: #4a90d9(1);
  }
  // Bottom half of V: from center-4 to bottom edge
  Group #StripV {
    Anchor: (Left: 28, Width: 8, Top: 28, Bottom: 0);
    Background: #4a90d9(1);
  }
}
