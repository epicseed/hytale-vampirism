$C = "../../Common.ui";

Group #RelicCooldownHudRoot {
  Anchor: (Right: 24, Bottom: 38, Width: 396, Height: 76);
  Visible: false;
  HitTestVisible: false;

  Group #SlotPrimary {
    Anchor: (Left: 0, Top: 0, Width: 76, Height: 76);
    HitTestVisible: false;

    Group #SlotHitArea {
      Anchor: (Full: 0);
      Background: (TexturePath: "../Assets/Shared/ItemQualities/Slots/SlotCommon.png");
      HitTestVisible: false;
    }

    Group #SlotIcon {
      Anchor: (Full: 0);
      Visible: false;
      Background: (TexturePath: "../Assets/Shared/WIPIcon.png");
      HitTestVisible: false;
    }

    Group #RarityOverlay {
      Anchor: (Full: 0);
      Visible: true;
      Background: (TexturePath: "../Assets/Shared/ItemQualities/Slots/SlotCommon_Overlay.png");
      HitTestVisible: false;
    }

    Group #CooldownOverlay {
      Anchor: (Full: 0);
      Visible: false;
      Background: #000000(0.62);
      HitTestVisible: false;
    }

    Label #CooldownText {
      Anchor: (Left: 6, Right: 6, Top: 22, Height: 28);
      Visible: false;
      Text: "";
      Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true, Alignment: Center);
      HitTestVisible: false;
    }

    Label #SlotHint {
      Anchor: (Left: 0, Right: 0, Bottom: 2, Height: 12);
      Text: "Primary";
      Style: (FontSize: 10, TextColor: #cfd8dc, RenderBold: true, Alignment: Center);
      HitTestVisible: false;
    }
  }

