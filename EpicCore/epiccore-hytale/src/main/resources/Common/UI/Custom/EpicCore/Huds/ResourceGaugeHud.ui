$C = "../../Common.ui";

@BottomMargin = 30;
@ContainerMargin = 6;
@HotbarSlotSpacingHud = 4;
@DefaultItemSlotsPerRow = 9;
@DefaultItemSlotSize = 74;
@DefaultItemGridPadding = 2;
@HotbarWidthHud = @DefaultItemSlotSize * @DefaultItemSlotsPerRow + @HotbarSlotSpacingHud * @DefaultItemSlotsPerRow;
@HotbarHeight = @DefaultItemSlotSize + (2 * @DefaultItemGridPadding);
@InventoryClosedContainerMargin = @BottomMargin + @ContainerMargin;

Group #MainContainer {
  Anchor: (Bottom: @InventoryClosedContainerMargin + @HotbarHeight + 26, Width: @HotbarWidthHud, Height: 24);
  HitTestVisible: false;

  Group #ResourceGaugeRow {
    Anchor: (Left: 0, Top: 0, Width: @HotbarWidthHud, Height: 24);
    LayoutMode: Left;
    HitTestVisible: false;

    Group {
      Anchor: (Left: 0, Width: 28, Height: 24, Top: 0);
      HitTestVisible: false;

      Group #Icon {
        Anchor: (Left: 0, Width: 24, Height: 24);
        Background: "../Assets/Huds/ResourceGauge/PrimaryIcon.png";
        HitTestVisible: false;
      }

      Group #IconAlternate {
        Anchor: (Left: 0, Width: 24, Height: 24);
        Background: "../Assets/Huds/ResourceGauge/AlternateIcon.png";
        Visible: false;
        HitTestVisible: false;
      }
    }

    Group #BarContainer {
      Anchor: (Left: 0, Width: 318, Height: 12);
      Background: "../Assets/Huds/ResourceGauge/GaugeBackground.png";
      HitTestVisible: false;

      ProgressBar #ProgressBarPrimary {
        Anchor: (Width: 318, Height: 12);
        BarTexturePath: "../Assets/Huds/ResourceGauge/GaugeFill.png";
        Value: 1.0;
      }

      ProgressBar #ProgressBarAlternate {
        Anchor: (Width: 318, Height: 12);
        BarTexturePath: "../Assets/Huds/ResourceGauge/GaugeAlternateFill.png";
        Value: 1.0;
        Visible: false;
      }

      ProgressBar #ProgressBarEffect {
        Anchor: (Width: 318, Height: 12);
        BarTexturePath: "../Assets/Huds/ResourceGauge/GaugeEffect.png";
        Value: 1.0;
      }

      Label #ValueMarker {
        Anchor: (Left: 0, Right: 0, Top: -1, Height: 12);
        Text: "100 / 100";
        Style: (FontSize: 10, TextColor: #ffd7d7, RenderBold: true, Alignment: Center);
        HitTestVisible: false;
      }
    }
  }
}
